<Window x:Class="MiniLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniLauncher"
        mc:Ignorable="d"
        Title="Mini Launcher"
        Width="680"
        Height="760"
        MinWidth="520"
        MinHeight="560"
        Opacity="0"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="True"
        AllowDrop="True"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Window.Resources>
        <DataTemplate x:Key="GridItemTemplate" DataType="{x:Type local:PinnedItem}">
            <Grid Width="138" Height="132">
                <Border x:Name="AppCard"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock Text="{Binding FavoriteBadge}"
                                       DockPanel.Dock="Right"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="12"
                                       FontWeight="Bold" />
                            <Border Background="{DynamicResource SoftAccentBrush}"
                                    CornerRadius="7"
                                    Padding="5,2"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Kind}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DockPanel>
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="{Binding IconImage}"
                                   Width="42"
                                   Height="42"
                                   Stretch="Uniform"
                                   Margin="0,0,0,10" />
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="108" />
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding MetaText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="10"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open" Click="OpenItem_Click" />
                            <MenuItem Header="Favorite" Click="ToggleFavorite_Click" />
                            <MenuItem Header="Rename" Click="RenameItem_Click" />
                            <MenuItem Header="Edit keywords" Click="EditKeywords_Click" />
                            <MenuItem Header="Change icon" Click="ChangeIcon_Click" />
                            <MenuItem Header="Open containing folder" Click="OpenContainingFolder_Click" />
                            <Separator />
                            <MenuItem Header="Move up" Click="MoveUpItem_Click" />
                            <MenuItem Header="Move down" Click="MoveDownItem_Click" />
                            <Separator />
                            <MenuItem Header="Unpin" Click="UnpinItem_Click" />
                        </ContextMenu>
                    </Border.ContextMenu>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <EventTrigger RoutedEvent="MouseEnter" SourceName="AppCard">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="AppCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1.045"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetName="AppCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1.045"
                                             Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave" SourceName="AppCard">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="AppCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetName="AppCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1"
                                             Duration="0:0:0.16" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ListItemTemplate" DataType="{x:Type local:PinnedItem}">
            <Border x:Name="ListCard"
                    Height="72"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="92" />
                    </Grid.ColumnDefinitions>
                    <Image Source="{Binding IconImage}"
                           Width="34"
                           Height="34"
                           Stretch="Uniform"
                           VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Path}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding FavoriteBadge}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Right"
                                   FontSize="12"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding MetaText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="10"
                                   Margin="0,3,0,0"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open" Click="OpenItem_Click" />
                        <MenuItem Header="Favorite" Click="ToggleFavorite_Click" />
                        <MenuItem Header="Rename" Click="RenameItem_Click" />
                        <MenuItem Header="Edit keywords" Click="EditKeywords_Click" />
                        <MenuItem Header="Change icon" Click="ChangeIcon_Click" />
                        <MenuItem Header="Open containing folder" Click="OpenContainingFolder_Click" />
                        <Separator />
                        <MenuItem Header="Move up" Click="MoveUpItem_Click" />
                        <MenuItem Header="Move down" Click="MoveDownItem_Click" />
                        <Separator />
                        <MenuItem Header="Unpin" Click="UnpinItem_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
            <DataTemplate.Triggers>
                <EventTrigger RoutedEvent="MouseEnter" SourceName="ListCard">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ListCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1.012"
                                             Duration="0:0:0.1" />
                            <DoubleAnimation Storyboard.TargetName="ListCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1.012"
                                             Duration="0:0:0.1" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave" SourceName="ListCard">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ListCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.14" />
                            <DoubleAnimation Storyboard.TargetName="ListCard"
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1"
                                             Duration="0:0:0.14" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Border x:Name="ShellRoot"
                Background="{DynamicResource ShellBrush}"
                CornerRadius="12"
                Effect="{StaticResource ShellShadow}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                MouseLeftButtonDown="Shell_MouseLeftButtonDown"
                RenderTransformOrigin="0.5,0.55">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
            </Border.RenderTransform>
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="46" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="7" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="M"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Mini Launcher"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="HeaderMetaText"
                                       Text="Alt + Space"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="10" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="&#xE710;" ToolTip="Add app" Style="{StaticResource IconButton}" Click="AddAppButton_Click" />
                        <Button Content="&#xE8B7;" ToolTip="Add folder" Style="{StaticResource IconButton}" Click="AddFolderButton_Click" />
                        <Button Content="&#xE711;" ToolTip="Hide" Style="{StaticResource IconButton}" Click="HideButton_Click" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,0"
                        Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="15" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}"
                                 FontSize="18"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 TextChanged="SearchBox_TextChanged"
                                 PreviewKeyDown="SearchBox_PreviewKeyDown" />
                        <Button Grid.Column="2"
                                Content="&#xE894;"
                                ToolTip="Clear search"
                                Style="{StaticResource IconButton}"
                                Click="ClearSearchButton_Click" />
                        <Border Grid.Column="3"
                                Background="{DynamicResource SoftAccentBrush}"
                                CornerRadius="7"
                                Padding="8,4"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="ResultCountText"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,14">
                    <ListBox x:Name="ItemsList"
                             Style="{StaticResource LauncherListBox}"
                             ItemContainerStyle="{StaticResource LauncherListBoxItem}"
                             KeyDown="ItemsList_KeyDown"
                             MouseDoubleClick="ItemsList_MouseDoubleClick">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <Grid x:Name="EmptyState" Visibility="Collapsed">
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="360">
                            <StackPanel>
                                <TextBlock Text="&#xE8E5;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="42"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="No pinned apps"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                    <Button Content="Add app" Style="{StaticResource PrimaryButton}" Click="AddAppButton_Click" />
                                    <Button Content="Add folder" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="AddFolderButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="StoreView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="2,0,2,10">
                            <StackPanel>
                                <TextBlock Text="Offline store"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="StoreHintText"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="11"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="Drop any app, shortcut, or folder here to pin it to the launcher."
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="11"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Content="Refresh"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="RefreshStore_Click" />
                        </DockPanel>
                        <ListBox x:Name="StoreList"
                                 Grid.Row="1"
                                 Style="{StaticResource LauncherListBox}"
                                 ItemContainerStyle="{StaticResource LauncherListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:StoreItem}">
                                    <Border Height="78"
                                            Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="112" />
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{Binding IconImage}" Width="36" Height="36" Stretch="Uniform" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Category}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Content="Install"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="InstallStoreItem_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <ScrollViewer x:Name="SettingsView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Settings"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="2,0,0,14" />
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Store path" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                    <DockPanel Margin="0,8,0,0">
                                        <Button Content="Browse"
                                                DockPanel.Dock="Right"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="BrowseStorePath_Click" />
                                        <TextBox x:Name="StorePathBox"
                                                 Margin="0,0,10,0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 BorderBrush="{DynamicResource LineBrush}"
                                                 TextChanged="StorePathBox_TextChanged" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Behavior" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <CheckBox x:Name="StartupCheckBox" Content="Start with Windows" Margin="0,0,18,8" Checked="StartupCheckBox_Changed" Unchecked="StartupCheckBox_Changed" />
                                        <CheckBox x:Name="TopmostCheckBox" Content="Always on top" Margin="0,0,18,8" Checked="BehaviorCheckBox_Changed" Unchecked="BehaviorCheckBox_Changed" />
                                        <CheckBox x:Name="AutoHideCheckBox" Content="Hide on lost focus" Margin="0,0,18,8" Checked="BehaviorCheckBox_Changed" Unchecked="BehaviorCheckBox_Changed" />
                                        <CheckBox x:Name="CursorPositionCheckBox" Content="Open near cursor" Margin="0,0,18,8" Checked="BehaviorCheckBox_Changed" Unchecked="BehaviorCheckBox_Changed" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="View mode" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <RadioButton x:Name="GridModeRadio" Content="Grid" IsChecked="True" Margin="0,0,18,0" Checked="ViewMode_Checked" />
                                        <RadioButton x:Name="ListModeRadio" Content="List" Checked="ViewMode_Checked" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Maintenance" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Open config" Style="{StaticResource PrimaryButton}" Click="OpenConfigButton_Click" />
                                        <Button Content="Export" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="ExportConfigButton_Click" />
                                        <Button Content="Import" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="ImportConfigButton_Click" />
                                        <Button Content="Clean missing" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="CleanMissingButton_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Hotkey" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="Alt + Space" Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="HomeButton" Content="&#xE80F;" ToolTip="Home" Style="{StaticResource IconButton}" Click="HomeButton_Click" />
                        <Button x:Name="StoreButton" Content="&#xE719;" ToolTip="Offline store" Style="{StaticResource IconButton}" Click="StoreButton_Click" />
                        <Button x:Name="SettingsButton" Content="&#xE713;" ToolTip="Settings" Style="{StaticResource IconButton}" Click="SettingsButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
